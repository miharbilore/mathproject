           "type": "MQ",
           "question": "A shipping company has $x^3 + 8$ cubic meters of cargo to transport. Which factored form is equivalent?",
           "options": {
               "A": "$(x + 2)(x^2 - 2x + 4)$",
               "B": "$(x - 2)(x^2 + 2x + 4)$",
               "C": "$x(x^2 + 8)$",
               "D": "$(x + 2)(x^2 - 2x - 4)$",
               "E": "$(x - 2)(x^2 + 2x - 4)$"
           },
           "answer": "A"
       },
