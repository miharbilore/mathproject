           "question": "What is the factored form of the quadratic equation $x^2 + 5x + 6 = 0$?",
           "options": {
               "A": "$(x + 2)(x + 3)$",
               "B": "$(x - 2)(x - 3)$",
               "C": "$(x + 2)(x - 3)$",
               "D": "$(x - 2)(x + 3)$",
               "E": "$(x + 1)(x + 4)$"
           },
           "answer": "A"
       },
